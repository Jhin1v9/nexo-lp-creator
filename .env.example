# ============================================================
# NEXO Landing Page Creator v3.0 - Environment Configuration
# ============================================================

# Server Configuration
PORT=3460
NODE_ENV=development
API_PREFIX=/api/nexo-lp

# Database
DATABASE_PATH=./data/nexo-lp.db

# AI Bridge Configuration (Luna Kimi Bridge via Playwright CDP)
# Set KIMI_BRIDGE_ENABLED=false to use the local mock generator (no Chrome/Kimi required).
KIMI_BRIDGE_ENABLED=true
# Use an isolated CDP port so NEXO LP Creator does not share Chrome with the Luna dashboard.
# The Luna bridge will start its own visible Chrome on this port if none exists.
KIMI_CDP_URL=http://127.0.0.1:9226
KIMI_CDP_PORT=9226
KIMI_MAX_PAGES=1
KIMI_TIMEOUT=120000
KIMI_IDLE_TIMEOUT=600000
KIMI_COOLDOWN_MS=5000
KIMI_MAX_TYPE_LENGTH=500
KIMI_MODE=thinking
KIMI_AUTO_START_CHROME=true
# Isolated Chrome profile so the LP Creator does not reuse the Luna dashboard session.
KIMI_CHROME_USER_DATA_DIR=${HOME}/.luna/nexo-lp-chrome-profile

# Test mode: reuse the same Luna userId to avoid opening many Kimi tabs
KIMI_BRIDGE_REUSE_USER_ID=false
# KIMI_BRIDGE_FIXED_USER_ID=nexo-lp-test

# Legacy Moonshot settings (no longer used by Luna bridge; kept for reference only)
# KIMI_BRIDGE_URL=https://api.moonshot.cn
# KIMI_BRIDGE_API_KEY=your_kimi_api_key_here
# KIMI_BRIDGE_MODEL=moonshot-v1-128k

# Token System
DEFAULT_TOKEN_BALANCE=50
TOKEN_COST_GENERATE=10
TOKEN_COST_DEPLOY=5
TOKEN_COST_REBUILD=3

# GitHub Pages Deployment
GITHUB_TOKEN=your_github_token_here
GITHUB_OWNER=your_github_username
GITHUB_REPO=your_landing_pages_repo
GITHUB_PAGES_BRANCH=gh-pages

# Preview Settings
PREVIEW_BASE_URL=http://localhost:3460
PREVIEW_STORAGE_PATH=./data/previews

# Mining Pipeline
MINING_ENABLED=true
MINING_QUEUE_SIZE=10
MINING_OUTPUT_PATH=./data/mined-templates

# Bug Detection
BUG_DETECTION_ENABLED=true
BUG_DETECTION_MAX_ISSUES=50

# Rebuild Engine
REBUILD_MAX_ATTEMPTS=3
REBUILD_AUTO_FIX_ENABLED=true

# Template System
TEMPLATES_PATH=./data/templates
TEMPLATE_VERSION=v3

# Stack Configuration
DEFAULT_STACK=static-html-tailwind
SUPPORTED_STACKS=static-html-tailwind,react-tailwind,vue-tailwind,html-css,nextjs-tailwind

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/nexo-lp.log

# Feature Flags
ENABLE_SSE=true
ENABLE_GITHUB_DEPLOY=true
ENABLE_ZIP_FALLBACK=true
ENABLE_TEMPLATE_MINING=true
ENABLE_BUG_DETECTION=true
