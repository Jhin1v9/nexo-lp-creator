{
  "name": "nexo-lp-creator",
  "version": "3.0.0",
  "description": "NEXO Landing Page Creator v3.0 - AI-powered landing page generation micro-product",
  "main": "nexo-lp-server/nexo-lp-server.js",
  "scripts": {
    "setup": "bash scripts/setup.sh",
    "dev:server": "cd nexo-lp-server && nodemon --config ../nodemon.json nexo-lp-server.js",
    "dev:web": "cd nexo-lp-web && npm run dev",
    "build": "npm run build:web",
    "build:web": "bash scripts/build.sh",
    "test": "bash scripts/test.sh",
    "test:e2e": "cd e2e && npx playwright test",
    "test:e2e:ui": "cd e2e && npx playwright test --ui",
    "test:e2e:debug": "cd e2e && npx playwright test --debug",
    "test:e2e:restaurant": "node scripts/e2e-restaurant-test.js",
    "import:kimi-chats": "node scripts/import-kimi-chats-to-loja.js",
    "generate:thumbnails": "node scripts/generate-template-thumbnails.js",
    "enrich:metadata": "node scripts/enrich-template-metadata.js",
    "cron:publish-unreviewed": "node scripts/cron-publish-unreviewed.js",
    "integrate": "bash scripts/verify-build.sh && bash scripts/run-all-tests.sh"
  },
  "keywords": [
    "landing-page",
    "ai",
    "generator",
    "nexo",
    "creator"
  ],
  "author": "NEXO Team",
  "license": "MIT",
  "dependencies": {
    "adm-zip": "^0.5.17",
    "archiver": "^7.0.1",
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^4.22.2",
    "helmet": "^7.2.0",
    "jsdom": "^29.1.1",
    "node-fetch": "^2.7.0",
    "turndown": "^7.2.4",
    "ws": "^8.21.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.0",
    "autoprefixer": "^10.5.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "playwright": "^1.61.0",
    "postcss": "^8.5.15",
    "supertest": "^7.0.0",
    "tailwindcss": "^4.3.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
